{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"outDir": "./dist-scripts",
		"rootDir": ".",
		"module": "commonjs",
		"moduleResolution": "node",
		"declaration": false,
		"sourceMap": false,
		"incremental": false,
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts"],
	"exclude": ["src/**/*.tsx", "node_modules", ".next", "tests", "test"]
}