# ============================================================
# SmartDeploy – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required variables are marked [REQUIRED].
# Everything else is optional and has sensible defaults.
# ============================================================

# --- Authentication [REQUIRED] --------------------------------

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth (optional second provider; https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Better Auth [REQUIRED]
# Used for encryption + cookie signing. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (used for OAuth callbacks / redirects)
BETTER_AUTH_URL=http://localhost:3000

# --- Database [REQUIRED] -------------------------------------

# Supabase (see docs/SUPABASE_SETUP.md)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (same Supabase project).
# Get from Supabase Dashboard -> Project Settings -> Database -> Connection string.
# IMPORTANT: This is server-only; never expose to the browser.
DATABASE_URL=

# Supabase Storage bucket for deployment screenshots (default: deployment-screenshots)
# DEPLOYMENT_SCREENSHOT_BUCKET=deployment-screenshots

# Global deploy metrics on the landing page and GET /api/metrics/public (default: true). Set to false to hide.
# PUBLIC_DEPLOY_METRICS_ENABLED=true

# --- PostHog (optional product analytics) ---------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# EU: https://eu.i.posthog.com
# If ad blockers block PostHog, you can proxy via your app:
# - set NEXT_PUBLIC_POSTHOG_HOST=/ph
# - set POSTHOG_UPSTREAM_HOST=https://us.i.posthog.com (or EU host)
# Send web vitals from local dev (default: off). Production always sends when the key is set.
# NEXT_PUBLIC_POSTHOG_CAPTURE_WEB_VITALS_IN_DEV=true
# Debug logs + one-time ping event on load (default: off).
# NEXT_PUBLIC_POSTHOG_DEBUG=true

# PostHog proxy upstream (server-side only; used by /ph/* route)
# POSTHOG_UPSTREAM_HOST=https://us.i.posthog.com

# PostHog server-side capture (used by deploy worker for `deploy_completed`)
# You can reuse the same Project API key as the browser.
# POSTHOG_API_KEY=
# Optional override (otherwise uses POSTHOG_UPSTREAM_HOST or defaults to US ingest)
# POSTHOG_HOST=https://us.i.posthog.com

# --- Artifact metrics -----------------------------------------
# New installs: included in supabase/schema.sql.
# Existing DBs: run supabase/artifact_metrics_rpc.sql in Supabase SQL Editor once.

# Artifact API used for generated deployment files
# SD_API_BEARER_TOKEN=sd-artifacts-api-token
# SD_API_BASE_URL=http://localhost:8080

# --- WebSocket ------------------------------------------------

# URL the browser uses to connect to the deploy worker
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# Comma-separated browser origins allowed to reach the worker
# WS_ALLOWED_ORIGINS=http://localhost:3000,https://smartdeploy.example.com

# Port the WebSocket server listens on (default: 4001)
# WS_PORT=4001

# --- AI / LLM -------------------------------------------------

# Google Gemini (recommended; get key at https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=

# Local LLM (Ollama-compatible; used as fallback if Gemini is not set)
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/api/generate
# LOCAL_LLM_MODEL=llama3.2

# AWS Bedrock (alternative LLM backend)
# AWS_BEDROCK_ACCESS_KEY_ID=
# AWS_BEDROCK_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=anthropic.claude-opus-4-5-v1:0

# --- AWS (for EC2 deployments) --------------------------------

# See docs/AWS_SETUP.md for IAM policy and related variables
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2

# ACM certificate ARN for ALB HTTPS (optional; see docs/CUSTOM_DOMAINS.md)
# EC2_ACM_CERTIFICATE_ARN=

# Build Docker images remotely via CodeBuild + ECR (default: true)
# USE_CODEBUILD=true

# Docker Hub credentials (optional; avoids anonymous pull rate limits in CodeBuild)
# Get a read-only token at https://hub.docker.com/settings/security
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# --- GCP (for Cloud Run deployments) --------------------------

# See docs/GCP_SETUP.md
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT_KEY=

# --- Custom Domains (see docs/CUSTOM_DOMAINS.md) --------------

# Base domain for deployment URLs (e.g. myapp.yourdomain.com)
# NEXT_PUBLIC_DEPLOYMENT_DOMAIN=yourdomain.com

# Vercel DNS integration (optional; auto-creates CNAME records)
# VERCEL_TOKEN=
# VERCEL_DOMAIN=yourdomain.com
# VERCEL_TEAM_ID=

# --- Miscellaneous --------------------------------------------

# "production" or "development"
# ENVIRONMENT=production

# Node heap for Docker build (default 2048 MB; increase on larger instances)
# NODE_MAX_OLD_SPACE_SIZE=2048
