# =============================================================================
# Smart Deploy — environment template
# Copy to .env and fill in your values:  cp .env.example .env
# See README.md and docs/AWS_SETUP.md for setup guides.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub OAuth (https://github.com/settings/developers)
# -----------------------------------------------------------------------------
GITHUB_ID=
GITHUB_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (https://console.cloud.google.com/apis/credentials)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Better Auth (shared secret between app and WebSocket worker)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase / Postgres
# See docs/SUPABASE_SETUP.md
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-us-west-2.pooler.supabase.com:6543/postgres
DB_POOL_MAX=5
DEPLOYMENT_SCREENSHOT_BUCKET=deployment-screenshots

# -----------------------------------------------------------------------------
# AI / LLM providers (at least one recommended for generation flows)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Optional: AWS Bedrock (falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# AWS_BEDROCK_ACCESS_KEY_ID=
# AWS_BEDROCK_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=

# Optional: local LLM (e.g. Ollama)
# LOCAL_LLM_BASE_URL=http://localhost:11434/api/generate
# LOCAL_LLM_MODEL=mistral

# -----------------------------------------------------------------------------
# SD Artifacts backend (scan, feedback, cache)
# -----------------------------------------------------------------------------
SD_API_BASE_URL=http://localhost:8080
SD_API_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# WebSocket worker
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:4001
WS_ALLOWED_ORIGINS=http://localhost:3000
# WS_PORT=4001
# Shared secret for Fargate deployment workers to POST live deploy logs to the websocket server.
DEPLOYMENT_EVENTS_TOKEN=
# Optional override; defaults to NEXT_PUBLIC_WS_URL converted to http(s).
# DEPLOYMENT_EVENTS_URL=http://localhost:4001

# -----------------------------------------------------------------------------
# Google Cloud Platform (optional; for GCP deploy paths)
# See docs/GCP_SETUP.md — paste service account JSON on one line
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=

# -----------------------------------------------------------------------------
# AWS credentials
# See docs/AWS_SETUP.md
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
NEXT_PUBLIC_AWS_REGION=us-west-2
DEPLOYMENT_QUEUE_URL=
# DEPLOYMENT_WORKER_TASK_DEFINITION_ARN=
# DEPLOYMENT_WORKER_CONTAINER_NAME=smart-deploy-worker
# DEPLOYMENT_WORKER_CLUSTER_NAME=
# DEPLOYMENT_WORKER_SUBNET_IDS=
# DEPLOYMENT_WORKER_SECURITY_GROUP_IDS=
# DEPLOYMENT_WORKER_ASSIGN_PUBLIC_IP=

# Build Docker images via CodeBuild + ECR instead of on the worker host
USE_CODEBUILD=true

# Docker Hub (optional; reduces anonymous rate limits during CodeBuild pulls)
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# -----------------------------------------------------------------------------
# Static site deploys (S3 + optional CloudFront)
# Provision with infra/smart-deploy-platform or set manually
# -----------------------------------------------------------------------------
STATIC_SITE_BUCKET=
STATIC_SITE_PUBLIC_BASE_URL=
# STATIC_SITE_KEY_PREFIX=
STATIC_SITE_CLOUDFRONT_DISTRIBUTION_ID=

# -----------------------------------------------------------------------------
# ECS Fargate (container / Railpack deploys)
# -----------------------------------------------------------------------------
ECS_CLUSTER_NAME=
ECS_SUBNET_IDS=
ECS_SECURITY_GROUP_IDS=
ECS_EXECUTION_ROLE_ARN=
ECS_LOG_GROUP=/ecs/smartdeploy-railpack
ECS_ASSIGN_PUBLIC_IP=DISABLED
# ECS_TASK_CPU=512
# ECS_TASK_MEMORY=1024

# -----------------------------------------------------------------------------
# Deploy logs (S3 bucket for pipeline JSONL logs)
# -----------------------------------------------------------------------------
LOGS_BUCKET=

# -----------------------------------------------------------------------------
# ACM certificate (optional; HTTPS on shared ALB — same region as AWS_REGION)
# -----------------------------------------------------------------------------
DEPLOYMENT_ACM_CERTIFICATE_ARN=

# -----------------------------------------------------------------------------
# Route 53 custom deployment subdomains
# See docs/CUSTOM_DOMAINS.md
# -----------------------------------------------------------------------------
ROUTE53_HOSTED_ZONE_ID=
ROUTE53_DOMAIN=
ROUTE53_USE_WILDCARD=true
ROUTE53_ENSURE_WILDCARD=true

# -----------------------------------------------------------------------------
# Deployment domain (subdomains like myapp.yourdomain.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEPLOYMENT_DOMAIN=smart-deploy.xyz

# -----------------------------------------------------------------------------
# Vercel DNS (optional legacy path; prefer Route 53 above)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_VERCEL_DOMAIN=
# VERCEL_DOMAIN=
# VERCEL_TOKEN=

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# PostHog analytics (optional)
# Browser traffic defaults to same-origin /ph proxy; set NEXT_PUBLIC_POSTHOG_HOST to override
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=/ph
NEXT_PUBLIC_POSTHOG_CAPTURE_WEB_VITALS_IN_DEV=false
NEXT_PUBLIC_POSTHOG_DEBUG=false
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_UPSTREAM_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Moss docs search for Deployment Agent search_docs (optional; uses @moss-dev/moss-core, Node 20+)
# -----------------------------------------------------------------------------
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
# MOSS_DOCS_INDEX_NAME=smart_deploy_help_docs
# npm run moss:index — create index; moss:index:refresh — upsert docs

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Set to false to skip approved-user gate (open sign-in)
WAITING_LIST_ENABLED=true
# Comma-separated emails that can access /admin
ADMIN_EMAILS=you@example.com
# Set to false to hide public deploy metrics on landing page
PUBLIC_DEPLOY_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Build tuning (Docker / low-memory EC2 — see docs/SELF_HOSTING.md)
# -----------------------------------------------------------------------------
# NODE_MAX_OLD_SPACE_SIZE=2048
