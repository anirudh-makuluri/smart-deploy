aws_region      = "us-west-2"
project_name    = "smart-deploy"
environment     = "prod"
instance_type   = "t3.small"

# Set to your static IP or office CIDR before applying.
ssh_cidr        = "203.0.113.10/32"

# Optional: leave empty to use default VPC + first subnet.
vpc_id          = ""
public_subnet_id = ""

# Optional key pair for SSH. Leave empty if using SSM only.
key_name        = ""

assign_eip      = true

domain_name     = "smart-deploy.xyz"
worker_subdomain = "ws"

allowed_origins = [
  "https://smart-deploy.xyz"
]

worker_port     = 4001
worker_image    = "328342419078.dkr.ecr.us-west-2.amazonaws.com/smart-deploy-worker:2026-04-17-1"
